generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ── NextAuth Models ──

model User {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  nickname      String?
  avatar        String?
  pin           String?
  accounts      Account[]
  favourites    Favourite[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  schoolProgress SchoolProgress[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ── Quiz Data ──

model Category {
  id                      String      @id @default(auto()) @map("_id") @db.ObjectId
  topic                   String
  emoji                   String
  description             String      @default("")
  categoryClass           String      @default("")
  hidden                  Boolean     @default(false)
  image                   String?
  storyText               String?
  storyImage              String?
  originalLang            String      @default("en")
  isTrending              Boolean     @default(false)
  chips                   String      @default("[]")
  sortOrder               Int         @default(0)
  showSubCategoriesOnHome Boolean     @default(false)

  parentId      String?     @db.ObjectId
  parent Category? @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subCategories Category[]  @relation("SubCategories")

  questions Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  text          String
  options       String
  correctAnswer String
  difficulty    String      @default("easy")
  image         String?

  categoryId String   @db.ObjectId
  category Category @relation(fields: [categoryId], references: [id])

  favourites Favourite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── User Features ──

model Favourite {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  questionId String   @db.ObjectId

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, questionId])
}

// ── Admin System ──

model AdminAccount {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  username     String             @unique
  passwordHash String
  displayName  String?
  role         String             @default("jr")
  status       String             @default("active")
  pendingTasks PendingTask[]
  activityLogs AdminActivityLog[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model PendingTask {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  adminId    String       @db.ObjectId
  admin      AdminAccount @relation(fields: [adminId], references: [id], onDelete: Cascade)
  actionType String
  entityType String
  entityId   String?
  payload    String
  status     String       @default("pending")
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model AdminActivityLog {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String       @db.ObjectId
  admin     AdminAccount @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime     @default(now())
}

// ── App Settings ──

model Setting {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  key   String @unique
  value String
}

model DailyQuiz {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String
  date        String
  categoryId  String   @db.ObjectId
  questionIds String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, date])
}

// ── School Module ──

model SchoolBoard {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  sortOrder Int           @default(0)
  hidden    Boolean       @default(false)
  classes   SchoolClass[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SchoolClass {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  boardId   String         @db.ObjectId
  board     SchoolBoard    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  number    Int
  subjects  SchoolSubject[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([boardId, number])
}

model SchoolSubject {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  classId   String          @db.ObjectId
  class     SchoolClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  sortOrder Int             @default(0)
  chapters  SchoolChapter[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([classId, slug])
}

model SchoolChapter {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  subjectId String           @db.ObjectId
  subject   SchoolSubject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int              @default(0)
  questions SchoolQuestion[]
  progress  SchoolProgress[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model SchoolQuestion {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  chapterId   String        @db.ObjectId
  chapter     SchoolChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  type        String
  prompt      String
  options     String        @default("[]")
  answer      String
  explanation String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SchoolProgress {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  userId        String        @db.ObjectId
  chapterId     String        @db.ObjectId
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter       SchoolChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  attempts      Int           @default(0)
  bestScore     Int           @default(0)
  lastScore     Int           @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, chapterId])
}
